{
  "name": "forge-app",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "pnpm --filter web dev",
    "dev:web": "pnpm --filter web dev:webpack",
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "test:api": "uv --directory apps/api run --active pytest -q",
    "lint": "pnpm -r lint",
    "lint:strict": "pnpm --filter web lint:strict",
    "typecheck": "pnpm -r typecheck",
    "ruff": "uv --directory apps/api run --active ruff check .",
    "ruff:fix": "uv --directory apps/api run --active ruff check --fix .",
    "mypy": "uv --directory apps/api run --active mypy",
    "verify": "pnpm lint:strict && pnpm typecheck && pnpm --filter web copy:check && pnpm -r test && pnpm ruff && pnpm mypy"
  }
}
