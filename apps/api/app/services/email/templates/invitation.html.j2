<!DOCTYPE html>
<html lang="en">
<head><meta charset="utf-8"/><title>Invitation</title></head>
<body style="margin:0;padding:24px;font-family:system-ui,sans-serif;background:#f6f6f6;">
  <table role="presentation" style="max-width:560px;margin:0 auto;background:#fff;border-radius:12px;padding:24px;">
    <tr><td>
      {% if logo_url %}<img src="{{ logo_url }}" alt="" height="40" style="margin-bottom:16px;"/>{% endif %}
      <h1 style="color:{{ primary_color|default('#111') }};">You've been invited to {{ org_name }}</h1>
      <p style="color:#374151;">Open Forge to accept your invitation.</p>
      {% if cta_url %}<p><a href="{{ cta_url }}" style="color:{{ primary_color|default('#2563eb') }};">Continue</a></p>{% endif %}
    </td></tr>
  </table>
</body>
</html>
