<!DOCTYPE html>
<html lang="en">
<head><meta charset="utf-8"/></head>
<body style="margin:0;padding:24px;font-family:system-ui,sans-serif;background:#f6f6f6;">
  <table role="presentation" style="max-width:560px;margin:0 auto;background:#fff;border-radius:12px;padding:24px;">
    <tr><td>
      {% if logo_url %}<img src="{{ logo_url }}" alt="" height="40" style="margin-bottom:16px;"/>{% endif %}
      <h1 style="color:{{ primary_color|default('#b91c1c') }};">We couldn't process your payment</h1>
      <p style="color:#374151;">{{ message }}</p>
      {% if billing_url %}<p><a href="{{ billing_url }}">Update billing</a></p>{% endif %}
    </td></tr>
  </table>
</body>
</html>
