<!DOCTYPE html>
<html lang="en">
<head><meta charset="utf-8"/><title>New submission</title></head>
<body style="margin:0;padding:32px;font-family:Inter,Arial,sans-serif;background:#f7f5ff;color:#151120;">
  <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="max-width:560px;margin:0 auto;background:#fff;border-radius:24px;padding:28px;border:1px solid #eee9ff;">
    <tr>
      <td>
        {% if logo_url %}<img src="{{ logo_url }}" alt="GlideDesign" height="40" style="margin-bottom:16px;display:block;"/>{% else %}<p style="margin:0 0 16px;color:#6651ff;font-weight:800;">GlideDesign</p>{% endif %}
        <h1 style="margin:0 0 12px;font-size:24px;letter-spacing:-0.04em;color:#151120;">New response — {{ page_title }}</h1>
        <p style="margin:0 0 16px;font-size:15px;line-height:1.5;color:#4f4b5f;">{{ org_name }} received a new response.</p>
        <div style="border:1px solid #eee9ff;border-radius:16px;padding:14px;font-size:14px;white-space:pre-wrap;background:#fbfaff;">{{ submission_summary }}</div>
        {% if voice_note %}<p style="margin-top:16px;font-size:13px;color:#6b7280;font-style:italic;">{{ voice_note }}</p>{% endif %}
        <p style="margin-top:28px;color:#8a8498;font-size:12px;">GlideDesign · glidedesign.ai</p>
      </td>
    </tr>
  </table>
</body>
</html>
