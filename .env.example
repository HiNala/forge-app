# Copying this file to a deployed environment? Do not use example values for any
# field marked REQUIRED IN PRODUCTION. Production startup rejects unsafe defaults.

# Frontend
# Do not set NODE_ENV here — Next.js sets it for `next dev` / `next build`. Putting NODE_ENV=development
# in .env can break production builds (Next.js 16 prerender of /_global-error). See vercel/next.js#87719.
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=https://glidedesign.ai
NEXT_PUBLIC_FORGE_OPERATOR_ORG_IDS=
# Alias for new deployments; keep NEXT_PUBLIC_FORGE_OPERATOR_ORG_IDS until all admin UI reads are migrated.
NEXT_PUBLIC_GLIDEDESIGN_OPERATOR_ORG_IDS=

# BP-03 War Room rollout (optional; prefs.studio_war_room_layout overrides)
# NEXT_PUBLIC_DEFAULT_STUDIO_WAR_ROOM_LAYOUT=1
# NEXT_PUBLIC_WAR_ROOM_DOGFOOD_DEFAULT=1

# --- Core ---
ENVIRONMENT=development
LOG_LEVEL=info
# REQUIRED IN PRODUCTION — generate with: openssl rand -hex 32
SECRET_KEY=change-me-use-openssl-rand-hex-32
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/forge_dev
REDIS_URL=redis://localhost:6379/0
# CORS — PRD lists CORS_ORIGINS; FastAPI settings use this name (use CSV or JSON array):
BACKEND_CORS_ORIGINS=http://localhost:3000
# Staging/prod extra origins (comma-separated); merged in code (BI-02).
CORS_ORIGINS_EXTRA=
# Comma-separated hosts for TrustedHostMiddleware. Do not use "*" in deployed environments.
TRUSTED_HOSTS=glidedesign.ai,www.glidedesign.ai,app.glidedesign.ai,api.glidedesign.ai,*.glidedesign.ai
# Subdomain tenant routing: `{slug}.{APP_ROOT_DOMAIN}` → resolve org by slug.
APP_ROOT_DOMAIN=
# Non-production: allow `?org=<uuid>` for manual testing (BI-02).
ALLOW_ORG_QUERY_PARAM=false
# Prefix for cache keys so dev/staging can share one Redis (BI-04).
FORGE_CACHE_NS=glidedesign
# Alias accepted by the API; FORGE_CACHE_NS remains supported for existing deployments.
GLIDEDESIGN_CACHE_NS=glidedesign
# Trust X-Forwarded-For for rate limits and public IP logging (set true behind a trusted LB)
TRUST_PROXY_HEADERS=false
# pytest: set true to test 429 behaviour (rate limit is otherwise disabled in test env)
FORCE_RATE_LIMIT_IN_TESTS=false
# Used for Stripe success URLs and invitation links (server-side)
APP_PUBLIC_URL=http://localhost:3000
API_BASE_URL=http://localhost:8000
UPGRADE_URL=http://localhost:3000/settings/billing

# --- First-party auth ---
# REQUIRED IN PRODUCTION — generate with: openssl rand -hex 32
AUTH_JWT_SECRET=
AUTH_JWT_ISSUER=glidedesign-api
AUTH_JWT_AUDIENCE=glidedesign-web
AUTH_ACCESS_TOKEN_TTL_SECONDS=900
AUTH_REFRESH_TOKEN_TTL_SECONDS=2592000
AUTH_PASSWORD_MIN_LENGTH=12
AUTH_TEST_BYPASS=false
FORGE_E2E_TOKEN=
# Alias accepted by the API; CI may continue using X-Forge-E2e-Token until contract migration.
GLIDEDESIGN_E2E_TOKEN=

# --- Object storage (S3-compatible: MinIO, AWS S3, Cloudflare R2) ---
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=forge-uploads
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_REGION=us-east-1
PUBLIC_ASSET_BASE_URL=http://localhost:9000/forge-uploads

# --- Email (Resend) ---
RESEND_API_KEY=
RESEND_WEBHOOK_SECRET=
EMAIL_FROM=GlideDesign <noreply@glidedesign.ai>

# --- Google Calendar OAuth ---
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
# --- Google Login OAuth (optional; falls back to GOOGLE_OAUTH_* if empty) ---
GOOGLE_AUTH_CLIENT_ID=
GOOGLE_AUTH_CLIENT_SECRET=

# --- Stripe (AL-02 — Free / Pro / Max tiers) ---
# REQUIRED IN PRODUCTION — must be a live key (`sk_live_...`)
STRIPE_SECRET_KEY=
# REQUIRED IN PRODUCTION — Stripe webhook signing secret (`whsec_...`)
STRIPE_WEBHOOK_SECRET=
# Self-serve subscription prices (`price_...` in Stripe test mode)
STRIPE_PRICE_PRO=
STRIPE_PRICE_PRO_ANNUAL=
STRIPE_PRICE_MAX_5X_MONTHLY=
STRIPE_PRICE_MAX_5X_ANNUAL=
STRIPE_PRICE_MAX_20X_MONTHLY=
STRIPE_PRICE_MAX_20X_ANNUAL=
# Metered extra generation credits. Legacy Stripe meter defaults remain `forge.credit.consumed`
# and `forge_credits` until the Stripe dashboard meter is migrated.
STRIPE_PRICE_EXTRA_USAGE_METERED=
# Optional — override default billing meter event name (must match dashboard meter)
FORGE_CREDIT_METER_EVENT_NAME=forge.credit.consumed
# Alias accepted by the API for post-dashboard-migration installs.
GLIDEDESIGN_CREDIT_METER_EVENT_NAME=
# Deprecated — Starter SKU replaced by Free + Checkout to Pro — leave empty in new installs
STRIPE_PRICE_STARTER=
# When true, Stripe Checkout sessions include automatic_tax.enabled (requires Stripe Tax configuration)
STRIPE_CHECKOUT_AUTOMATIC_TAX=false

# --- LLM providers ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
LLM_DEFAULT_PROVIDER=openai
LLM_MODEL_INTENT=gpt-4o-mini
LLM_MODEL_COMPOSE=gpt-4o
LLM_MODEL_SECTION_EDIT=gpt-4o-mini
LLM_TIMEOUT_SECONDS=120
LLM_FALLBACK_MODELS=
LLM_LOG_METRICS=true
USE_AGENT_COMPOSER=false
USE_PRODUCT_ORCHESTRATOR=true

# --- Quotas & limits (override per plan in production as needed) ---
PAGE_GENERATION_LIMIT_STARTER=20
PAGE_GENERATION_LIMIT_PRO=200
SUBMISSIONS_LIMIT_STARTER=500
SUBMISSIONS_LIMIT_PRO=10000
PAGE_GENERATION_QUOTA_TRIAL=100
PAGE_GENERATION_QUOTA_PRO=100000
STUDIO_GENERATE_PER_MINUTE_TRIAL=5
STUDIO_GENERATE_PER_MINUTE_PRO=30
# Clarify chip follow-up window (seconds) for /generate/continue with run_id (AL-03)
CLARIFY_SESSION_TTL_SECONDS=1800
TEAM_INVITE_RATE_LIMIT_PER_MINUTE=10

# --- Analytics (PostHog — optional) ---
POSTHOG_API_KEY=
POSTHOG_HOST=https://us.i.posthog.com

# --- Observability ---
SENTRY_DSN=
# Prometheus /metrics bearer token. Leave empty in dev. In prod, set at least
# 32 random characters and configure your Prometheus scrape job with `bearer_token`.
METRICS_TOKEN=

# --- Platform / admin ---
FORGE_OPERATOR_ORG_IDS=
GLIDEDESIGN_OPERATOR_ORG_IDS=
FORGE_ADMIN_DATABASE_URL=
GLIDEDESIGN_ADMIN_DATABASE_URL=

# --- Caddy on-demand TLS (`ask` endpoint on API) ---
CADDY_INTERNAL_TOKEN=

# --- Rate limit / tests (normally false in deployed envs) ---
RATE_LIMIT_IN_TESTS=false
FORCE_RATE_LIMIT_IN_TESTS=false

# --- Railway CLI (local only; not required by app runtime) ---
# RAILWAY_TOKEN=
