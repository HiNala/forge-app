# Frontend
# Do not set NODE_ENV here — Next.js sets it for `next dev` / `next build`. Putting NODE_ENV=development
# in .env can break production builds (Next.js 16 prerender of /_global-error). See vercel/next.js#87719.
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=https://forge.app
NEXT_PUBLIC_FORGE_OPERATOR_ORG_IDS=

# --- Core ---
ENVIRONMENT=development
LOG_LEVEL=info
SECRET_KEY=change-me-use-openssl-rand-hex-32
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/forge_dev
REDIS_URL=redis://localhost:6379/0
SECRET_KEY=
# CORS — PRD lists CORS_ORIGINS; FastAPI settings use this name (use CSV or JSON array):
BACKEND_CORS_ORIGINS=http://localhost:3000
# Staging/prod extra origins (comma-separated); merged in code (BI-02).
CORS_ORIGINS_EXTRA=
# Trust X-Forwarded-For for rate limits and public IP logging (set true behind a trusted LB)
TRUST_PROXY_HEADERS=false
# pytest: set true to test 429 behaviour (rate limit is otherwise disabled in test env)
FORCE_RATE_LIMIT_IN_TESTS=false
# Used for Stripe success URLs and invitation links (server-side)
APP_PUBLIC_URL=http://localhost:3000
API_BASE_URL=http://localhost:8000
UPGRADE_URL=http://localhost:3000/settings/billing

# --- Clerk ---
CLERK_JWKS_URL=
CLERK_JWT_ISSUER=
CLERK_AUDIENCE=
CLERK_WEBHOOK_SECRET=
AUTH_TEST_BYPASS=false
FORGE_E2E_TOKEN=

# --- Object storage (S3-compatible: MinIO, AWS S3, Cloudflare R2) ---
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=forge-uploads
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_REGION=us-east-1
PUBLIC_ASSET_BASE_URL=http://localhost:9000/forge-uploads

# --- Email (Resend) ---
RESEND_API_KEY=
RESEND_WEBHOOK_SECRET=
EMAIL_FROM=noreply@forge.app

# --- Google Calendar OAuth ---
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# --- Stripe ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO=
STRIPE_PRICE_STARTER=

# --- LLM providers ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
LLM_DEFAULT_PROVIDER=openai
LLM_MODEL_INTENT=gpt-4o-mini
LLM_MODEL_COMPOSE=gpt-4o
LLM_MODEL_SECTION_EDIT=gpt-4o-mini
LLM_TIMEOUT_SECONDS=120
LLM_FALLBACK_MODELS=
LLM_LOG_METRICS=true
USE_AGENT_COMPOSER=false

# --- Quotas & limits (override per plan in production as needed) ---
PAGE_GENERATION_LIMIT_STARTER=20
PAGE_GENERATION_LIMIT_PRO=200
SUBMISSIONS_LIMIT_STARTER=500
SUBMISSIONS_LIMIT_PRO=10000
PAGE_GENERATION_QUOTA_TRIAL=100
PAGE_GENERATION_QUOTA_PRO=100000
STUDIO_GENERATE_PER_MINUTE_TRIAL=5
STUDIO_GENERATE_PER_MINUTE_PRO=30
TEAM_INVITE_RATE_LIMIT_PER_MINUTE=10

# --- Analytics (PostHog — optional) ---
POSTHOG_API_KEY=
POSTHOG_HOST=https://us.i.posthog.com

# --- Observability ---
SENTRY_DSN=

# --- Platform / admin ---
FORGE_OPERATOR_ORG_IDS=
FORGE_ADMIN_DATABASE_URL=

# --- Caddy on-demand TLS (`ask` endpoint on API) ---
CADDY_INTERNAL_TOKEN=

# --- Rate limit / tests (normally false in deployed envs) ---
RATE_LIMIT_IN_TESTS=false
FORCE_RATE_LIMIT_IN_TESTS=false

# --- Railway CLI (local only; not required by app runtime) ---
# RAILWAY_TOKEN=
