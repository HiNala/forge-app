# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Backend
ENVIRONMENT=development
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/forge_dev
REDIS_URL=redis://localhost:6379/0
SECRET_KEY=
BACKEND_CORS_ORIGINS=http://localhost:3000

# Auth (Clerk — see docs/architecture/DECISIONS.md ADR-002)
AUTH_PROVIDER=clerk
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_WEBHOOK_SECRET=

# LLM (LiteLLM router — see apps/api/app/services/ai/router.py)
LLM_DEFAULT_PROVIDER=openai
LLM_MODEL_INTENT=gpt-4o-mini
LLM_MODEL_COMPOSE=gpt-4o
LLM_MODEL_SECTION_EDIT=gpt-4o-mini
LLM_TIMEOUT_SECONDS=120
# Comma-separated fallback models when the primary fails (optional)
LLM_FALLBACK_MODELS=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# Storage
STORAGE_PROVIDER=minio
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=forge-uploads
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_REGION=us-east-1

# Email
RESEND_API_KEY=
EMAIL_FROM=noreply@forge.app
EMAIL_REPLY_TO=support@forge.app

# Google Calendar
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3000/api/auth/calendar/callback

# Billing
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO=
STRIPE_PRICE_STARTER=

# Internal admin API — comma-separated organization UUIDs (e.g. Digital Studio Labs)
FORGE_OPERATOR_ORG_IDS=

# Monitoring
SENTRY_DSN=
LOG_LEVEL=INFO
